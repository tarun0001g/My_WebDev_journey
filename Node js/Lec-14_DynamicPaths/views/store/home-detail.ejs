
<%- include("../partials/header") %>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col">

  <!-- ✅ Navbar Added -->
  <%- include("../partials/nav") %>

  <!-- ✅ Detail Section -->
  <section class="py-8 px-4 md:px-6">
    <div class="max-w-5xl mx-auto">
      
      <!-- Breadcrumb -->
      <div class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-gray-700">Home</a> / <span>Property Details</span>
      </div>

      <!-- Main Grid -->
      <div class="grid md:grid-cols-3 gap-8">
        
        <!-- Left - Image -->
        <div class="md:col-span-2">
          <div class="bg-gray-300 rounded-lg overflow-hidden shadow-md h-80 md:h-96">
            <img src="<%= home.photoURL %>" alt="<%= home.HouseName %>" class="w-full h-full object-cover">
          </div>
        </div>

        <!-- Right - Details Card -->
        <div class="bg-white rounded-lg shadow-md p-6">
          
          <!-- Name & Rating -->
          <h1 class="text-2xl font-bold text-gray-900 mb-2">
            <%= home.HouseName %>
          </h1>
          <div class="flex items-center gap-2 mb-4 pb-4 border-b border-gray-200">
            <span class="text-yellow-500">⭐</span>
            <span class="font-semibold text-gray-800"><%= home.rating %>/5</span>
          </div>

          <!-- Location -->
          <div class="mb-6">
            <p class="text-gray-500 text-sm mb-1">Location</p>
            <p class="text-gray-800 font-medium flex items-center gap-2">
              <span>📍</span><%= home.location %>
            </p>
          </div>

          <!-- Price -->
          <div class="mb-6 pb-6 border-b border-gray-200">
            <p class="text-gray-500 text-sm mb-2">Price per Night</p>
            <p class="text-3xl font-bold text-rose-500">
              ₹<%= home.price %>
            </p>
          </div>

          <!-- Buttons -->
          <div class="space-y-3">
            <button class="w-full bg-rose-500 hover:bg-rose-600 text-white py-2.5 rounded-lg font-semibold transition-colors duration-300 shadow-sm">
              Book Now
            </button>
            <%- include("../partials/favourite") %>
            
          </div>

        </div>

      </div>

    </div>
  </section>

</body>
</html>

