
<%- include("partials/header") %>
</head>
<body class="bg-gray-100 min-h-screen flex flex-col">

    <!-- ✅ Navbar Added -->
<%- include("partials/nav") %>

  <!-- ✅ Hero Section -->
  <section class="text-center mt-12 px-4">
    <h2 class="text-4xl font-extrabold text-gray-800 mb-3">
      Find Your Perfect Stay
    </h2>

    <p class="text-gray-500 text-lg">
      Discover beautiful homes and amazing experiences.
    </p>
  </section>

  <!-- ✅ Listings Section -->
  <main class="flex-grow max-w-7xl mx-auto px-6 py-10">

    <h3 class="text-2xl font-bold text-gray-800 mb-6">
      Available Homes
    </h3>

    <!-- Grid -->
    <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">

      <% if (registeredHomes.length === 0) { %>
        <p class="text-gray-500">No homes added yet.</p>
      <% } %>

      <% registeredHomes.forEach(home => { %>
        <!-- Card -->
        <div class="bg-white rounded-2xl shadow-md hover:shadow-xl transition overflow-hidden">
          <!-- Fake Image Block -->
          <div class="h-40 bg-gradient-to-r from-rose-400 to-pink-500"></div>
          <div class="p-4">
            <h4 class="text-lg font-semibold text-gray-800 mb-2">
              <%= home.HouseName %>
            </h4>
            <p class="text-sm text-gray-500 italic font-medium tracking-wide">
              ✨ Beautiful and comfortable place to stay.
            </p>

            <button class="mt-4 w-full bg-rose-500 hover:bg-rose-600 text-white py-2 rounded-lg font-semibold transition">
              View Details
            </button>
          </div>
        </div>
      <% }) %>

    </div>

  </main>

  <!-- ✅ Footer -->
<%- include("partials/footer") %>

</body>
</html>


